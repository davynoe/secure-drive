{
  "compilerOptions": {
    "target": "ESNext",
    "module": "Node16",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "baseUrl": ".",
    "outDir": "dist",
    "moduleResolution": "Node16",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "allowSyntheticDefaultImports": true,
    "lib": ["DOM", "ESNext"],
    "rootDir": "./src",
    "ignoreDeprecations": "6.0",
    "types": ["vite/client", "node"]
  }
  ,
  "include": ["src", "forge.env.d.ts", "vite-env.d.ts"]
}
